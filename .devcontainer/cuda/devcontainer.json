{
  "name": "tenferro-benchmark (CUDA)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "../.."
  },
  "remoteUser": "vscode",
  "runArgs": ["--gpus", "all"],
  "containerEnv": {
    "OPENBLAS_ROOT": "/opt/openblas",
    "PYTORCH_OPENBLAS_DIR": "${containerWorkspaceFolder}/extern/devcontainer/pytorch-openblas",
    "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
    "USE_CUDA": "1",
    "USE_ROCM": "0",
    "USE_MPS": "0",
    "USE_DISTRIBUTED": "0",
    "CUDA_HOME": "/usr/local/cuda",
    "LD_LIBRARY_PATH": "/usr/local/cuda/lib64",
    "TENFERRO_CUTENSOR_PATH": "/usr/lib/x86_64-linux-gnu/libcutensor/12/libcutensor.so.2",
    "TENFERRO_CUSOLVER_PATH": "/usr/local/cuda/lib64/libcusolver.so",
    "TENFERRO_CUBLAS_PATH": "/usr/local/cuda/lib64/libcublas.so",
    "CUBECL_DEBUG_LOG": "0"
  },
  "remoteEnv": {
    "PATH": "/home/vscode/.cargo/bin:/home/vscode/.local/bin:${containerEnv:PATH}"
  },
  "mounts": [
    "source=tenferro-benchmark-cuda-cargo-registry,target=/home/vscode/.cargo/registry,type=volume",
    "source=tenferro-benchmark-cuda-cargo-git,target=/home/vscode/.cargo/git,type=volume",
    "source=tenferro-benchmark-cuda-uv-cache,target=/home/vscode/.cache/uv,type=volume"
  ],
  "postCreateCommand": "uv sync --frozen || uv sync && uv pip install 'torch>=2.12.0' --extra-index-url https://download.pytorch.org/whl/cu126 && uv pip install 'jax[cuda12]'",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "ms-python.python",
        "ms-vscode.cmake-tools",
        "nvidia.nsight-vscode-edition"
      ]
    }
  }
}
