{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tensor4all.example/schemas/benchmark-suite.schema.json",
  "title": "Benchmark Suite",
  "type": "object",
  "required": [
    "schema_version",
    "suite_id",
    "title",
    "description",
    "defaults",
    "backends",
    "problems"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "suite_id": {
      "type": "string",
      "pattern": "^(cpu|gpu)/[a-z0-9][a-z0-9_.-]*$"
    },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "defaults": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "run": { "$ref": "#/$defs/run" },
        "verify": { "$ref": "#/$defs/verify" },
        "device": { "$ref": "#/$defs/device" },
        "layout": { "$ref": "#/$defs/layout" }
      }
    },
    "backends": { "$ref": "#/$defs/backend_list" },
    "problems": {
      "oneOf": [
        { "$ref": "#/$defs/problem_selector" },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/problem" }
        }
      ]
    }
  },
  "$defs": {
    "backend_list": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "problem_selector": {
      "type": "object",
      "required": ["source", "include"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "include": { "$ref": "#/$defs/problem_id_list" },
        "exclude": { "$ref": "#/$defs/problem_id_list" }
      }
    },
    "problem_id_list": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "device": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "enum": ["cpu", "cuda"] },
        "ordinal": { "type": "integer", "minimum": 0 }
      }
    },
    "run": {
      "type": "object",
      "required": ["warmups", "runs"],
      "additionalProperties": false,
      "properties": {
        "warmups": { "type": "integer", "minimum": 0 },
        "runs": { "type": "integer", "minimum": 1 },
        "min_runtime_ms": { "type": "number", "minimum": 0 },
        "timing_scope": {
          "enum": [
            "steady_state_host_api",
            "steady_state_device_only",
            "steady_state_host_api_plus_device_sync",
            "steady_state_host_api_plus_device_sync_with_download",
            "compile_plus_first_run"
          ]
        }
      }
    },
    "verify": {
      "type": "object",
      "required": ["reference", "rtol", "atol"],
      "additionalProperties": true,
      "properties": {
        "reference": { "type": "string", "minLength": 1 },
        "rtol": { "type": "number", "minimum": 0 },
        "atol": { "type": "number", "minimum": 0 },
        "residual_rtol": { "type": "number", "minimum": 0 }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tenferro": { "enum": ["col_major"] },
        "framework": { "enum": ["row_major_contiguous"] },
        "sparse": { "enum": ["csr"] }
      }
    },
    "dtype": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "a": { "type": "string" },
        "b": { "type": "string" },
        "c": { "type": "string" },
        "values": { "type": "string" },
        "x": { "type": "string" },
        "y": { "type": "string" },
        "accum": { "type": "string" }
      }
    },
    "data": {
      "type": "object",
      "required": ["generator", "seed"],
      "additionalProperties": true,
      "properties": {
        "generator": {
          "enum": [
            "normal",
            "zeros",
            "well_conditioned",
            "spd",
            "symmetric_normal",
            "suitesparse",
            "tensornetwork_fill"
          ]
        },
        "seed": { "type": "integer" }
      }
    },
    "problem": {
      "type": "object",
      "required": [
        "id",
        "family",
        "op",
        "dtype",
        "data"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "intent": { "type": "string", "minLength": 1 },
        "notes": { "type": "string", "minLength": 1 },
        "family": { "enum": ["dense", "sparse", "einsum", "tensornetwork"] },
        "op": {
          "enum": [
            "matmul",
            "batched_matmul",
            "einsum",
            "tensor_network_contract",
            "qr",
            "solve",
            "svd",
            "eigh",
            "spmv",
            "spmm"
          ]
        },
        "dtype": { "$ref": "#/$defs/dtype" },
        "layout": { "$ref": "#/$defs/layout" },
        "data": { "$ref": "#/$defs/data" },
        "run": { "$ref": "#/$defs/run" },
        "verify": { "$ref": "#/$defs/verify" },
        "only_backends": { "$ref": "#/$defs/backend_list" },
        "skip_backends": { "$ref": "#/$defs/backend_list" },
        "matmul": { "$ref": "#/$defs/matmul" },
        "batched_matmul": { "$ref": "#/$defs/batched_matmul" },
        "einsum": { "$ref": "#/$defs/einsum" },
        "tensor_network": { "$ref": "#/$defs/tensor_network" },
        "linalg": { "$ref": "#/$defs/linalg" },
        "sparse": { "$ref": "#/$defs/sparse" }
      },
      "allOf": [
        {
          "if": { "properties": { "family": { "const": "dense" } } },
          "then": {
            "properties": {
              "op": {
                "enum": [
                  "matmul",
                  "batched_matmul",
                  "qr",
                  "solve",
                  "svd",
                  "eigh"
                ]
              }
            }
          }
        },
        {
          "if": { "properties": { "family": { "const": "einsum" } } },
          "then": { "properties": { "op": { "const": "einsum" } } }
        },
        {
          "if": { "properties": { "family": { "const": "tensornetwork" } } },
          "then": { "properties": { "op": { "const": "tensor_network_contract" } } }
        },
        {
          "if": { "properties": { "family": { "const": "sparse" } } },
          "then": { "properties": { "op": { "enum": ["spmv", "spmm"] } } }
        },
        {
          "if": { "properties": { "op": { "const": "matmul" } } },
          "then": {
            "required": ["matmul"],
            "not": {
              "anyOf": [
                { "required": ["batched_matmul"] },
                { "required": ["einsum"] },
                { "required": ["linalg"] },
                { "required": ["sparse"] }
              ]
            }
          }
        },
        {
          "if": { "properties": { "op": { "const": "batched_matmul" } } },
          "then": {
            "required": ["batched_matmul"],
            "not": {
              "anyOf": [
                { "required": ["matmul"] },
                { "required": ["einsum"] },
                { "required": ["linalg"] },
                { "required": ["sparse"] }
              ]
            }
          }
        },
        {
          "if": { "properties": { "op": { "const": "einsum" } } },
          "then": {
            "required": ["einsum"],
            "not": {
              "anyOf": [
                { "required": ["matmul"] },
                { "required": ["batched_matmul"] },
                { "required": ["tensor_network"] },
                { "required": ["linalg"] },
                { "required": ["sparse"] }
              ]
            }
          }
        },
        {
          "if": { "properties": { "op": { "const": "tensor_network_contract" } } },
          "then": {
            "required": ["tensor_network"],
            "not": {
              "anyOf": [
                { "required": ["matmul"] },
                { "required": ["batched_matmul"] },
                { "required": ["einsum"] },
                { "required": ["linalg"] },
                { "required": ["sparse"] }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "op": { "enum": ["qr", "solve", "svd", "eigh"] }
            }
          },
          "then": {
            "required": ["linalg"],
            "not": {
              "anyOf": [
                { "required": ["matmul"] },
                { "required": ["batched_matmul"] },
                { "required": ["einsum"] },
                { "required": ["sparse"] }
              ]
            }
          }
        },
        {
          "if": { "properties": { "op": { "enum": ["qr", "svd"] } } },
          "then": {
            "properties": {
              "linalg": { "required": ["m", "n"] }
            }
          }
        },
        {
          "if": { "properties": { "op": { "const": "solve" } } },
          "then": {
            "properties": {
              "linalg": { "required": ["n", "rhs_cols"] }
            }
          }
        },
        {
          "if": { "properties": { "op": { "const": "eigh" } } },
          "then": {
            "properties": {
              "linalg": { "required": ["n"] }
            }
          }
        },
        {
          "if": { "properties": { "op": { "enum": ["spmv", "spmm"] } } },
          "then": {
            "required": ["sparse"],
            "not": {
              "anyOf": [
                { "required": ["matmul"] },
                { "required": ["batched_matmul"] },
                { "required": ["einsum"] },
                { "required": ["linalg"] }
              ]
            }
          }
        },
        {
          "if": { "properties": { "op": { "const": "spmm" } } },
          "then": {
            "properties": {
              "sparse": { "required": ["rhs_cols"] }
            }
          }
        }
      ]
    },
    "matmul": {
      "type": "object",
      "required": ["m", "n", "k"],
      "additionalProperties": false,
      "properties": {
        "m": { "type": "integer", "minimum": 1 },
        "n": { "type": "integer", "minimum": 1 },
        "k": { "type": "integer", "minimum": 1 },
        "transpose_a": { "type": "boolean" },
        "transpose_b": { "type": "boolean" }
      }
    },
    "batched_matmul": {
      "type": "object",
      "required": ["batch", "m", "n", "k", "batch_layout"],
      "additionalProperties": false,
      "properties": {
        "batch": { "type": "integer", "minimum": 1 },
        "m": { "type": "integer", "minimum": 1 },
        "n": { "type": "integer", "minimum": 1 },
        "k": { "type": "integer", "minimum": 1 },
        "batch_layout": { "enum": ["leading", "trailing"] }
      }
    },
    "einsum": {
      "type": "object",
      "required": [
        "format_rowmajor",
        "format_colmajor",
        "shapes_rowmajor",
        "shapes_colmajor",
        "path"
      ],
      "additionalProperties": false,
      "properties": {
        "format_rowmajor": { "type": "string", "minLength": 1 },
        "format_colmajor": { "type": "string", "minLength": 1 },
        "shapes_rowmajor": { "$ref": "#/$defs/shape_list" },
        "shapes_colmajor": { "$ref": "#/$defs/shape_list" },
        "path": {
          "type": "object",
          "required": ["strategy", "pairs"],
          "additionalProperties": false,
          "properties": {
            "strategy": { "enum": ["opt_flops", "opt_size", "manual"] },
            "pairs": {
              "type": "array",
              "items": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    },
    "tensor_network": {
      "type": "object",
      "required": ["source", "bond_dim", "fill_value", "execution"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "bond_dim": { "type": "integer", "minimum": 1 },
        "fill_value": { "type": "number" },
        "execution": { "enum": ["tree"] }
      }
    },
    "shape_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "integer", "minimum": 1 }
      }
    },
    "linalg": {
      "type": "object",
      "required": ["n"],
      "additionalProperties": false,
      "properties": {
        "m": { "type": "integer", "minimum": 1 },
        "n": { "type": "integer", "minimum": 1 },
        "rhs_cols": { "type": "integer", "minimum": 1 },
        "batch": { "type": "integer", "minimum": 1 },
        "full_matrices": { "type": "boolean" }
      }
    },
    "sparse": {
      "type": "object",
      "required": ["source", "storage", "rows", "cols", "nnz"],
      "additionalProperties": false,
      "properties": {
        "source": { "enum": ["suitesparse", "matrix_market"] },
        "group": { "type": "string" },
        "name": { "type": "string" },
        "storage": { "enum": ["csr"] },
        "rows": { "type": "integer", "minimum": 1 },
        "cols": { "type": "integer", "minimum": 1 },
        "nnz": { "type": "integer", "minimum": 0 },
        "rhs_cols": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
